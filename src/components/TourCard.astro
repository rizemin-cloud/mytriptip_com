---
interface Props {
  name: string;
  duration: string;
  description: string;
  priceFrom?: string;
  bookingUrl: string;
  image?: string;
  cancellation?: string;
  meetingPoint?: string;
}

const { name, duration, description, priceFrom, bookingUrl, image, cancellation, meetingPoint } = Astro.props;
---

<div class="border border-border rounded-lg overflow-hidden mb-6 hover:shadow-md transition-shadow">
  <div class="flex flex-col sm:flex-row">
    {image && (
      <div class="sm:w-48 h-40 sm:h-auto flex-shrink-0">
        <img src={image} alt={name} class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
    <div class="p-5 flex-1">
      <h3 class="font-semibold text-lg">{name}</h3>
      <div class="flex flex-wrap gap-3 mt-1 text-xs text-text-muted">
        <span>{duration}</span>
        {cancellation && <span>{cancellation}</span>}
        {meetingPoint && <span>From: {meetingPoint}</span>}
      </div>
      <p class="mt-2 text-sm text-text-muted leading-relaxed">{description}</p>
      <div class="mt-3 flex items-center justify-between">
        {priceFrom && (
          <span class="text-sm font-medium text-accent">From {priceFrom}</span>
        )}
        <a
          href={bookingUrl}
          target="_blank"
          rel="noopener noreferrer nofollow sponsored"
          class="inline-block px-5 py-2 bg-accent text-white text-sm font-medium rounded-md hover:bg-accent-dark transition-colors"
        >
          See available tours
        </a>
      </div>
    </div>
  </div>
</div>
