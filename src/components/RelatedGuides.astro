---
interface GuideLink {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  guides: GuideLink[];
  heading?: string;
}

const { guides, heading = 'Related Guides' } = Astro.props;
---

{guides.length > 0 && (
  <section class="mt-12 pt-8 border-t border-border">
    <h2 class="text-xl font-semibold mb-4">{heading}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {guides.map(({ title, href, description }) => (
        <a
          href={href}
          class="block p-4 border border-border rounded-lg hover:border-primary hover:shadow-sm transition-all group"
        >
          <p class="font-medium group-hover:text-primary transition-colors">{title}</p>
          {description && (
            <p class="text-sm text-text-muted mt-1">{description}</p>
          )}
        </a>
      ))}
    </div>
  </section>
)}
