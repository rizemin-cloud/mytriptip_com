---
interface Props {
  name: string;
  area: string;
  description: string;
  priceRange?: string;
  bookingUrl: string;
  image?: string;
  bestFor?: string;
}

const { name, area, description, priceRange, bookingUrl, image, bestFor } = Astro.props;
---

<div class="border border-border rounded-lg overflow-hidden mb-6 hover:shadow-md transition-shadow">
  <div class="flex flex-col sm:flex-row">
    {image && (
      <div class="sm:w-48 h-40 sm:h-auto flex-shrink-0">
        <img src={image} alt={name} class="w-full h-full object-cover" loading="lazy" />
      </div>
    )}
    <div class="p-5 flex-1">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h3 class="font-semibold text-lg">{name}</h3>
          <p class="text-sm text-text-muted">{area}</p>
        </div>
        {priceRange && (
          <span class="text-sm font-medium text-accent whitespace-nowrap">{priceRange}</span>
        )}
      </div>
      <p class="mt-2 text-sm text-text-muted leading-relaxed">{description}</p>
      {bestFor && (
        <p class="mt-2 text-xs text-green-700">
          <span class="font-medium">Best for:</span> {bestFor}
        </p>
      )}
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer nofollow sponsored"
        class="mt-3 inline-block px-5 py-2 bg-accent text-white text-sm font-medium rounded-md hover:bg-accent-dark transition-colors"
      >
        Check prices
      </a>
    </div>
  </div>
</div>
