---
import HubLayout from '../layouts/HubLayout.astro';
import RelatedGuides from '../components/RelatedGuides.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => {
  return data.category === 'transport' && !data.draft;
});

const guides = allArticles.map((article) => ({
  title: article.data.title,
  href: `/${article.id}/`,
  description: article.data.description,
}));

const crossLinks = [
  { title: 'Where to Stay in Seoul', href: '/seoul/where-to-stay/', description: 'Pick the right neighborhood near transit' },
  { title: 'Korea eSIM vs Pocket WiFi', href: '/basics/esim-vs-pocket-wifi/', description: 'Get connected for navigation apps' },
  { title: 'Booking.com vs Agoda vs Trip.com', href: '/compare/booking-vs-agoda-vs-tripdotcom/', description: 'Compare hotel booking platforms' },
];
---

<HubLayout
  title="Getting Around Korea"
  description="Airport transfers, intercity trains, buses, and transit cards. Everything you need to move around Korea confidently."
  breadcrumbs={[{ name: 'Transport', url: '/transport/' }]}
  noindex={guides.length === 0}
>
  {guides.length > 0 ? (
    <>
      <p class="max-w-3xl text-text-muted mb-6">
        These guides answer the transport questions that create the most friction on a first trip:
        airport arrival, train cards, and when a more expensive transfer is actually worth paying for.
      </p>
      <RelatedGuides guides={guides} heading="Transport Guides" />
    </>
  ) : (
    <div>
      <p class="text-text-muted mb-6">Transport guides are coming soon. Start planning your Korea trip with these:</p>
      <RelatedGuides guides={crossLinks} heading="Helpful Guides" />
    </div>
  )}
</HubLayout>
