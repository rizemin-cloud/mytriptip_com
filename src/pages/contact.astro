---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with the MyTripTip team for corrections, feedback, or partnership inquiries."
>
  <article class="mx-auto max-w-3xl px-4 py-12 prose prose-slate">
    <h1>Contact Us</h1>

    <p>
      Have a question, correction, or feedback? We'd love to hear from you.
    </p>

    <h2>General Inquiries</h2>
    <p>
      Email: <strong>hello@mytriptip.com</strong>
    </p>

    <h2>Corrections & Updates</h2>
    <p>
      Found outdated or incorrect information in one of our guides? Please email us
      with the page URL and the correction. We take accuracy seriously and will update
      the guide promptly.
    </p>

    <h2>Partnership & Advertising</h2>
    <p>
      For partnership or advertising inquiries, please email
      <strong>partners@mytriptip.com</strong>.
    </p>
  </article>
</BaseLayout>
