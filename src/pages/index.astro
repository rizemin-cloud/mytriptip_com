---
import BaseLayout from '../layouts/BaseLayout.astro';
import DestinationHubGrid from '../components/DestinationHubGrid.astro';
import RelatedGuides from '../components/RelatedGuides.astro';

const destinations = [
  {
    title: 'Seoul',
    href: '/seoul/',
    description: 'Where to stay, airport transfers, top tours, and nightlife for first-time visitors.',
  },
  {
    title: 'Busan',
    href: '/busan/',
    description: 'Beach neighborhoods, KTX from Seoul, and the best hotels in Haeundae.',
  },
];

const quickLinks = [
  { title: 'Where to Stay in Korea', href: '/where-to-stay/', description: 'Best areas and hotels by destination' },
  { title: 'Tours & Tickets', href: '/tours-tickets/', description: 'DMZ, day trips, and experience bookings' },
  { title: 'Airport & Train Transport', href: '/transport/', description: 'ICN transfers, buses, and intercity travel basics' },
  { title: 'eSIM & Transport Cards', href: '/sim-money/', description: 'Stay connected and get around cheaply' },
  { title: 'Travel Basics', href: '/travel-basics/', description: 'Budget, transit cards, and first-timer planning essentials' },
  { title: '4-Day Seoul Itinerary', href: '/seoul/4-days-itinerary/', description: 'A realistic first-trip route without wasted transit time' },
  { title: 'Compare Platforms', href: '/compare/', description: 'Booking.com vs Agoda, Viator vs Klook, and more' },
];
---

<BaseLayout
  title="MyTripTip"
  description="Practical Korea travel guides for first-time visitors. Decide where to stay, how to move, what to book, and what eSIM to buy."
>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
      Your first trip to Korea,<br />figured out.
    </h1>
    <p class="text-lg text-text-muted max-w-2xl mb-10">
      We help first-time visitors decide where to stay, how to get around, what tours to book, and which eSIM to buy. No fluff — just practical answers.
    </p>

    <a
      href="/start-here/"
      class="inline-block px-6 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors mb-12"
    >
      Start planning your trip
    </a>

    <DestinationHubGrid destinations={destinations} heading="Choose Your Destination" />

    <RelatedGuides guides={quickLinks} heading="Popular Guides" />
  </section>
</BaseLayout>
