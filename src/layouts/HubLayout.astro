---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TrustBox from '../components/TrustBox.astro';
import type { BreadcrumbItem } from '../utils/seo';

interface Props {
  title: string;
  description: string;
  breadcrumbs?: BreadcrumbItem[];
  noindex?: boolean;
}

const { title, description, breadcrumbs, noindex = false } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={noindex}>
  <div class="mx-auto max-w-6xl px-4 py-8">
    {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumb items={breadcrumbs} />}
    <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-3">{title}</h1>
    <p class="text-lg text-text-muted mb-8 max-w-2xl">{description}</p>
    <slot />
    <TrustBox />
  </div>
</BaseLayout>
